# ============================================================
# free-tour-bus 환경변수 예시 파일
# ============================================================
# 이 파일은 저장소에 커밋됩니다. 실제 값은 절대 입력하지 마세요.
# 실제 값은 env.local 파일에 보관하고 .gitignore로 제외합니다.
#
# 사용 방법:
#   1. 이 파일을 복사하여 env.local 파일을 생성합니다.
#      $ cp .env.example env.local
#   2. env.local 파일에 실제 값을 입력합니다.
#   3. env.local은 절대 Git에 커밋하지 않습니다.
# ============================================================

# ── Supabase ──────────────────────────────────────────────
# Supabase 프로젝트 URL (대시보드 → Settings → API → Project URL)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon (공개) 키 (대시보드 → Settings → API → anon public)
# 클라이언트 사이드에서 RLS 정책 하에 사용됩니다.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Supabase Service Role 키 (대시보드 → Settings → API → service_role)
# ⚠️  절대 클라이언트에 노출하지 마세요. RLS를 우회합니다.
# ⚠️  서버 사이드 API Route에서만 사용합니다.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── 관리자 계정 ───────────────────────────────────────────
# 관리자 로그인 ID (이메일 형식 권장)
ADMIN_ID=admin@example.com

# 관리자 로그인 비밀번호 (영문+숫자+특수문자 조합, 12자 이상 권장)
ADMIN_PASSWORD=your-strong-password-here

# ── 사이트 URL ────────────────────────────────────────────
# 운영 환경 기본 URL (Supabase Auth 리다이렉트, 이메일 링크 생성에 사용)
# 로컬 개발: http://localhost:3000
# 운영 환경: https://www.free-bus.co.kr
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── SMS (Solapi) ──────────────────────────────────────────
# Solapi API 키 (https://console.solapi.com → 개발 → API Key 관리)
# SOLAPI_API_KEY=your-solapi-api-key-here

# Solapi API Secret
# SOLAPI_API_SECRET=your-solapi-api-secret-here

# 발신 전화번호 (Solapi에 등록된 번호) — 환경변수명: SOLAPI_SENDER_NUMBER
# SOLAPI_SENDER_NUMBER=01012345678
# (구버전 호환: SOLAPI_SENDER_PHONE 도 인식합니다)
